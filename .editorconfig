root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4

[*.{xlsx,pptx,thmx,png}]
# Binary files — let git handle them as-is
end_of_line = unset
trim_trailing_whitespace = unset
insert_final_newline = unset
